.page { padding: 30rpx; }
.intro, .empty { padding: 28rpx; color: #746d62; line-height: 1.7; }
.card { margin-bottom: 24rpx; padding: 30rpx; border: 1rpx solid #e0d5c6; border-radius: 22rpx; background: #fffaf2; }
.card__top { display: flex; justify-content: space-between; gap: 20rpx; }
.card__title { font-family: serif; font-size: 36rpx; font-weight: 700; }
.card__meta { margin-top: 10rpx; color: #8a8175; font-size: 24rpx; }
.card__description { margin-top: 22rpx; color: #59534a; line-height: 1.7; }
.badge { color: #8c332d; font-size: 22rpx; }
.error { margin-top: 14rpx; color: #b63e34; }
.actions { display: flex; gap: 18rpx; margin-top: 24rpx; }
.actions button { margin: 0; }
.primary { background: #26352d; color: white; }

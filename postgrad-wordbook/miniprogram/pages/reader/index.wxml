<view class="toolbar">
  <text>{{start + 1}}–{{end}} / {{total}}</text>
  <text>字号：{{fontSize}}</text>
</view>
<view class="filters">
  <view class="search-row">
    <input value="{{query}}" placeholder="搜索单词或释义" bindinput="onSearchInput"/>
    <button size="mini" bindtap="clearFilters">清空</button>
  </view>
  <scroll-view scroll-x class="letters">
    <text wx:for="{{letters}}" wx:key="*this"
      class="letter {{letter === item ? 'letter--active' : ''}}"
      data-letter="{{item}}" bindtap="selectLetter">{{item}}</text>
  </scroll-view>
  <checkbox-group class="familiarity-filter" bindchange="onFamiliarityFilter">
    <label><checkbox value="familiar" checked="{{familiarityChecks.familiar}}"/>熟悉</label>
    <label><checkbox value="review" checked="{{familiarityChecks.review}}"/>待巩固</label>
    <label><checkbox value="unknown" checked="{{familiarityChecks.unknown}}"/>陌生</label>
  </checkbox-group>
</view>
<scroll-view class="reader" scroll-y enhanced show-scrollbar="{{false}}"
  scroll-into-view="{{scrollIntoView}}" bindscrolltolower="loadMore" bindscroll="onReaderScroll">
  <view wx:if="{{loading}}" class="loading">正在打开词书…</view>
  <view wx:for="{{words}}" wx:key="id" class="entry-anchor"
    id="entry-anchor-{{item.id}}" data-word-id="{{item.id}}">
    <word-entry word="{{item}}" font-size="{{fontSize}}"
      familiarity="{{stateById[item.id].familiarity}}"
      bind:familiaritychange="onFamiliarityChange"/>
  </view>
  <view wx:if="{{empty}}" class="end">没有符合条件的单词</view>
  <view wx:if="{{!loading && end >= total}}" class="end">本词库已阅读到底</view>
</scroll-view>
